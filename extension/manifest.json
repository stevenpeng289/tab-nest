{
  "manifest_version": 3,
  "name": "TabNest",
  "version": "1.5.0",
  "description": "Organize tabs, bookmark boards, and work sessions from a calm new tab page. One-tap stash via the toolbar icon.",
  "permissions": [
    "tabs",
    "storage",
    "favicon",
    "bookmarks"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TabNest",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
