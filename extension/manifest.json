{
  "manifest_version": 3,
  "name": "TabNest",
  "version": "1.0.0",
  "description": "Organize, stash, and reorder your tabs from a calm new tab page.",
  "permissions": ["tabs", "storage", "favicon"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "TabNest",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
